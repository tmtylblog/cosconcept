# ─── Database (Neon PostgreSQL) ───────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Neo4j Aura ──────────────────────────────────────────
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ─── Better Auth ─────────────────────────────────────────
BETTER_AUTH_SECRET=generate-a-random-string-at-least-32-chars-long
BETTER_AUTH_URL=http://localhost:3000

# ─── Google OAuth ────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── AI Keys ────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...
# GOOGLE_AI_API_KEY=...
# DEEPGRAM_API_KEY=...

# ─── Stripe (optional until billing is live) ──────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# STRIPE_PRO_YEARLY_PRICE_ID=price_...
# STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_...
# STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_...

# ─── Enrichment (optional in Phase 0) ───────────────────
# JINA_API_KEY=jina_...
# PROXYCURL_API_KEY=...

# ─── Monitoring (optional in Phase 0) ───────────────────
# SENTRY_DSN=https://xxx@oyyy.ingest.us.sentry.io/zzz
