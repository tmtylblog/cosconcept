# ─── Database (Neon PostgreSQL) ───────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Neo4j Aura ──────────────────────────────────────────
# NOTE: As of 2026-03-11, we migrated to a cloned Neo4j Aura instance.
# Get the current URI + password from Vercel env vars or ask the team.
NEO4J_URI=neo4j+s://13a38041.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=ask-team-for-password

# ─── Better Auth ─────────────────────────────────────────
BETTER_AUTH_SECRET=generate-a-random-string-at-least-32-chars-long
BETTER_AUTH_URL=http://localhost:3000

# ─── Google OAuth ────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── AI Keys ────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...
# GOOGLE_AI_API_KEY=...
# DEEPGRAM_API_KEY=...

# ─── Stripe ───────────────────────────────────────────────
# Use test keys (sk_test_...) until ready for live payments.
# App works without these — billing UI shows "coming soon".
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret: `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_...
# Create prices in Stripe Dashboard → Products
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_...

# ─── Customer.io ─────────────────────────────────────────
# ONLY the App API key is used in code — Track API is intentionally excluded
# to prevent triggering live campaigns on production data.
CUSTOMERIO_APP_API_KEY=
CUSTOMERIO_WEBHOOK_SIGNING_KEY=
# DO NOT use these in code — stored for reference only:
# CUSTOMERIO_TRACKING_SITE_ID=
# CUSTOMERIO_TRACKING_API_KEY=

# ─── Background Jobs ──────────────────────────────────────
# Required for /api/jobs/worker endpoint authentication.
# CRON_SECRET is auto-set by Vercel for cron jobs.
JOBS_SECRET=generate-a-random-secret-string
# CRON_SECRET=auto-set-by-vercel

# ─── Enrichment (optional in Phase 0) ───────────────────
# JINA_API_KEY=jina_...
# PROXYCURL_API_KEY=...

# ─── Monitoring (optional in Phase 0) ───────────────────
# SENTRY_DSN=https://xxx@oyyy.ingest.us.sentry.io/zzz
